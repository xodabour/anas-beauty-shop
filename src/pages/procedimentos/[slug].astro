---
import MainLayout from "../../layouts/MainLayout.astro";
import GoogleReviews from "../../components/services/GoogleReviews.astro";
import FAQServico from "../../components/services/FAQServico.astro";
import CTAAgendamento from "../../components/services/CTAAgendamento.astro";
import MapaServico from "../../components/services/MapaServico.astro";

import { procedimentos } from "../../data/procedimentos";

export function getStaticPaths() {
  return Object.values(procedimentos).map((procedimento) => ({
    params: {
      slug: procedimento.slug,
    },
    props: {
      procedimento,
    },
  }));
}

const { procedimento } = Astro.props;
---

<MainLayout
  title={procedimento.tituloSeo}
  description={procedimento.descricaoSeo}
  keywords={`${procedimento.nome} Balneário Camboriú, ${procedimento.categoria}, salão de beleza Balneário Camboriú`}
  image={procedimento.imagemHero}
  canonical={`https://www.anasbeautyshop.com.br/procedimentos/${procedimento.slug}`}
>
  <main class="bg-black text-white">
    <section class="relative min-h-[85vh] flex items-center bg-black overflow-hidden">
      <div
        class="absolute inset-0 bg-cover bg-center"
        style={`background-image: url('${procedimento.imagemHero}');`}
      ></div>

      <div class="absolute inset-0 bg-black/70"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-black via-black/80 to-transparent"></div>

      <div class="relative z-10 max-w-7xl mx-auto px-6 pt-32 pb-20 w-full">
        <div class="max-w-3xl">
          <span class="text-yellow-500 uppercase tracking-[0.35em] text-xs md:text-sm">
            {procedimento.categoria}
          </span>

          <h1 class="font-luxury text-4xl md:text-7xl font-semibold leading-tight mt-6">
            {procedimento.titulo}
          </h1>

          <p class="text-gray-300 text-lg md:text-xl mt-6 mb-8 leading-relaxed">
            {procedimento.subtitulo}
          </p>

          <div class="inline-block bg-[#111111] border border-yellow-500/20 rounded-2xl px-6 py-4 mb-8">
            <span class="text-gray-400 text-sm block mb-1">
              Valor
            </span>

            <strong class="text-yellow-400 text-2xl">
              {procedimento.preco}
            </strong>
          </div>

          <div>
            <a
              href={procedimento.whatsapp}
              target="_blank"
              class="inline-block w-full sm:w-auto bg-yellow-500 text-black px-8 md:px-10 py-4 rounded-full font-semibold text-center hover:bg-yellow-400 hover:scale-105 transition-all duration-300"
            >
              Agendar pelo WhatsApp
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-[#080808] py-20 px-6">
      <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="text-yellow-500 uppercase tracking-[0.3em] text-sm">
            Sobre o procedimento
          </span>

          <h2 class="font-luxury text-4xl md:text-5xl font-semibold mt-4 mb-8">
            {procedimento.nome} no Ana's Beauty Shop
          </h2>

          <div class="space-y-6">
            {procedimento.introducao.map((paragrafo) => (
              <p class="text-gray-300 text-lg leading-relaxed">
                {paragrafo}
              </p>
            ))}
          </div>
        </div>

        <div class="rounded-3xl overflow-hidden border border-yellow-500/20 shadow-2xl shadow-black/50">
          <img
            src={procedimento.imagemDestaque}
            alt={procedimento.nome}
            class="w-full h-[360px] md:h-[460px] object-cover"
          />
        </div>
      </div>
    </section>

    <section class="bg-black py-24 px-6">
      <div class="max-w-7xl mx-auto text-center">
        <span class="text-yellow-500 uppercase tracking-[0.35em] text-sm">
          Benefícios
        </span>

        <h2 class="font-luxury text-4xl md:text-5xl font-semibold mt-4 mb-14">
          Por que escolher este procedimento?
        </h2>

        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-5">
          {procedimento.beneficios.map((beneficio) => (
            <div class="bg-[#111111] border border-yellow-500/20 rounded-3xl p-6">
              <div class="text-yellow-500 text-3xl mb-4">✓</div>
              <p class="text-gray-300">{beneficio}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <GoogleReviews />

    <FAQServico servico={{ faq: procedimento.faq }} />

    <CTAAgendamento servico={procedimento} />

    <MapaServico />
  </main>
</MainLayout>