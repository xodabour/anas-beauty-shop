---
import "../styles/global.css";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FloatingWhatsApp from "../components/FloatingWhatsApp.astro";

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  image?: string;
  canonical?: string;
}

const {
  title = "Ana's Beauty Shop | Salão de Beleza em Balneário Camboriú",
  description = "Ana's Beauty Shop em Balneário Camboriú. Especialistas em cabelos, depilação, maquiagem, saúde capilar, sobrancelhas e unhas.",
  keywords = "salão de beleza Balneário Camboriú, cabeleireiro, manicure, maquiagem, depilação, sobrancelha, saúde capilar",
  image = "/images/hero-salao.png",
  canonical = "https://www.anasbeautyshop.com.br",
} = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "BeautySalon",
  "@id": "https://www.anasbeautyshop.com.br/#anasbeautyshop",
  name: "Ana's Beauty Shop",
  url: "https://www.anasbeautyshop.com.br",
  image: "https://www.anasbeautyshop.com.br/images/logo-dourada.png",
  logo: "https://www.anasbeautyshop.com.br/images/logo-dourada.png",
  description:
    "Salão de beleza em Balneário Camboriú especializado em cabelos, depilação, maquiagem, saúde capilar, sobrancelhas e unhas.",
  telephone: "+5547991620575",
  priceRange: "$$",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Rua 1536, nº 719",
    addressLocality: "Balneário Camboriú",
    addressRegion: "SC",
    postalCode: "88330-610",
    addressCountry: "BR",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: -26.9931239,
    longitude: -48.6359855,
  },
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Tuesday", "Wednesday", "Thursday", "Friday"],
      opens: "09:00",
      closes: "19:00",
    },
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: "Saturday",
      opens: "09:00",
      closes: "17:00",
    },
  ],
  sameAs: [
    "https://www.instagram.com/anas_beautyshop/",
  ],
  areaServed: {
    "@type": "City",
    name: "Balneário Camboriú",
  },
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Serviços de beleza",
    itemListElement: [
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Cabelo",
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Depilação",
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Unhas",
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Maquiagem",
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Sobrancelhas",
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Saúde Capilar",
        },
      },
    ],
  },
};
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>

    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Ana's Beauty Shop" />
    <meta name="robots" content="index, follow" />

    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/images/logo-dourada.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={canonical} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>

  <body class="bg-black text-white">
    <Header />

    <slot />

    <Footer />
    <FloatingWhatsApp />
  </body>
</html>