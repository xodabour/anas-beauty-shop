---
import { config } from "../data/config";
import { ui } from "../data/ui";
---

<section
  id="localizacao"
  class={`bg-[#050505] text-white ${ui.section}`}
>
  <div class={ui.container}>

    <div class="text-center mb-16">
      <span class={ui.eyebrow}>
        Nossa Localização
      </span>

      <h2 class={`${ui.title} text-[#8a561f] mt-4 mb-6`}>
        Atendemos em {config.cidade}
      </h2>

      <p class={`${ui.paragraph} max-w-3xl mx-auto`}>
        Um espaço pensado para proporcionar conforto, sofisticação e momentos
        de cuidado em uma das cidades mais encantadoras de Santa Catarina.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 items-center">

      <div class="space-y-10">

        <div class="flex gap-5 items-start">
          <div class="text-3xl text-yellow-500">
            📍
          </div>

          <div>
            <h3 class="text-2xl font-semibold text-white mb-3">
              Visite Nosso Espaço
            </h3>

            <p class={`${ui.paragraph} text-lg`}>
              {config.endereco}
            </p>

            <p class="text-gray-400 mt-4 leading-relaxed">
              Um ambiente pensado para proporcionar conforto,
              bem-estar e uma experiência de beleza exclusiva.
            </p>
          </div>
        </div>

        <div class="flex gap-5 items-start">
          <div class="text-3xl text-yellow-500">
            🕒
          </div>

          <div>
            <h3 class="text-2xl font-semibold text-white mb-3">
              Horário de Atendimento
            </h3>

            <p class={`${ui.paragraph} text-lg`}>
              {config.horario.semana}<br />
              {config.horario.sabado}
            </p>
          </div>
        </div>

        <div class="flex gap-5 items-start">
          <div class="text-3xl text-yellow-500">
            📱
          </div>

          <div>
            <h3 class="text-2xl font-semibold text-white mb-3">
              Agendamentos
            </h3>

            <p class={`${ui.paragraph} mb-6`}>
              Entre em contato pelo WhatsApp e reserve seu horário com nossa equipe.
            </p>

            <a
              href={config.whatsapp("Olá! Gostaria de agendar um horário no Ana's Beauty Shop.")}
              target="_blank"
              rel="noopener noreferrer"
              class={ui.buttonPrimary}
            >
              Agendar pelo WhatsApp
            </a>
          </div>
        </div>

      </div>

      <div class={ui.imageCard}>
        <iframe
          src={config.googleMapsEmbed}
          width="100%"
          height="520"
          style="border:0;"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>

    </div>

  </div>
</section>