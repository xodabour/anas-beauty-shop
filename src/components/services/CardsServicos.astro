---
type ServicoOferecido = {
  titulo: string;
  texto: string;
};

const { servico } = Astro.props;
---

<section class="bg-black text-white py-24 px-6">
  <div class="max-w-7xl mx-auto">

    <div class="text-center mb-16">

      <span class="text-yellow-500 uppercase tracking-[0.35em] text-sm">
        Serviços
      </span>

      <h2 class="font-luxury text-4xl md:text-5xl font-semibold mt-4">
        Tudo o que oferecemos
      </h2>

      <p class="text-gray-300 mt-6 max-w-3xl mx-auto text-lg">
        Trabalhamos com técnicas modernas, produtos profissionais e atendimento
        personalizado para proporcionar resultados que valorizam sua beleza.
      </p>

    </div>

    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">

      {servico.servicosOferecidos.map((item: ServicoOferecido) => (

        <article
          class="group bg-[#111111] rounded-3xl border border-yellow-500/20 p-8 hover:border-yellow-500 hover:-translate-y-2 transition-all duration-500"
        >

          <div
            class="w-16 h-16 rounded-full bg-yellow-500/10 border border-yellow-500/30 flex items-center justify-center text-3xl text-yellow-500 mb-6"
          >
            ✦
          </div>

          <h3
            class="font-luxury text-3xl text-yellow-400 mb-5"
          >
            {item.titulo}
          </h3>

          <p
            class="text-gray-300 leading-relaxed"
          >
            {item.texto}
          </p>

        </article>

      ))}

    </div>

  </div>
</section>