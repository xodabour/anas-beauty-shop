---
const { servico } = Astro.props;
---

<section
  class="relative min-h-[85vh] flex items-center bg-black overflow-hidden"
>
  <div
    class="absolute inset-0 bg-cover bg-center"
    style={`background-image: url('${servico.imagemHero}');`}
  ></div>

  <div class="absolute inset-0 bg-black/70"></div>
  <div class="absolute inset-0 bg-gradient-to-r from-black via-black/80 to-transparent"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 pt-32 pb-20 w-full">
    <div class="max-w-3xl">
      <span class="text-yellow-500 uppercase tracking-[0.35em] text-xs md:text-sm">
        {servico.nome}
      </span>

      <h1 class="font-luxury text-4xl md:text-7xl font-semibold leading-tight mt-6">
        {servico.titulo}
      </h1>

      <p class="text-gray-300 text-lg md:text-xl mt-6 mb-10 leading-relaxed">
        {servico.subtitulo}
      </p>

      <a
        href={servico.whatsapp}
        target="_blank"
        class="inline-block w-full sm:w-auto bg-yellow-500 text-black px-8 md:px-10 py-4 rounded-full font-semibold text-center hover:bg-yellow-400 hover:scale-105 transition-all duration-300"
      >
        Agendar pelo WhatsApp
      </a>
    </div>
  </div>
</section>