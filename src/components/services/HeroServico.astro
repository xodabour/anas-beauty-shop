---
import type { HeroServicoData } from "../../types/componentes";
import { ui } from "../../data/ui";

interface Props {
  servico: HeroServicoData;
}

const { servico } = Astro.props as Props;
---

<section class="relative min-h-[85vh] flex items-center bg-black overflow-hidden">
  <div
    class="absolute inset-0 bg-cover bg-center"
    style={`background-image: url('${servico.imagemHero}');`}
  ></div>

  <div class="absolute inset-0 bg-black/70"></div>
  <div class="absolute inset-0 bg-gradient-to-r from-black via-black/80 to-transparent"></div>

  <div class={`relative z-10 ${ui.container} px-6 pt-32 pb-20 w-full`}>
    <div class="max-w-3xl">
      {servico.categoria && (
        <span class="text-yellow-500 uppercase tracking-[0.35em] text-xs md:text-sm">
          {servico.categoria}
        </span>
      )}

      <h1 class={`${ui.titleHero} mt-6`}>
        {servico.titulo}
      </h1>

      <p class={`${ui.paragraph} md:text-xl mt-6 mb-8`}>
        {servico.subtitulo}
      </p>

      {servico.preco && (
        <div class="inline-block bg-[#111111] border border-yellow-500/20 rounded-2xl px-6 py-4 mb-8">
          <span class="text-gray-400 text-sm block mb-1">
            Valor
          </span>

          <strong class="text-yellow-400 text-2xl">
            {servico.preco}
          </strong>
        </div>
      )}

      <div>
        <a
          href={servico.whatsapp}
          target="_blank"
          rel="noopener noreferrer"
          class={ui.buttonPrimary}
        >
          Agendar pelo WhatsApp
        </a>
      </div>
    </div>
  </div>
</section>