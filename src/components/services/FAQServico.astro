---
import type { FAQServicoData } from "../../types/componentes";
import { ui } from "../../data/ui";

interface Props {
  servico: FAQServicoData;
}

const { servico } = Astro.props as Props;
---

<section class={`bg-[#080808] text-white ${ui.section}`}>
  <div class={ui.containerSmall}>
    <div class="text-center mb-16">
      <span class={ui.eyebrow}>
        Perguntas Frequentes
      </span>

      <h2 class={`${ui.title} mt-4`}>
        Tire suas dúvidas
      </h2>

      <p class={`${ui.paragraph} mt-6 max-w-3xl mx-auto`}>
        Separamos algumas respostas para as dúvidas mais comuns sobre nossos
        serviços.
      </p>
    </div>

    <div class="space-y-6">
      {servico.faq.map((item) => (
        <details
          class="group bg-black border border-yellow-500/20 rounded-3xl p-6 open:border-yellow-500 transition-all"
        >
          <summary class="flex items-center justify-between cursor-pointer list-none">
            <h3 class="font-semibold text-lg md:text-xl text-yellow-400 pr-4">
              {item.pergunta}
            </h3>

            <span class="text-yellow-500 text-3xl group-open:rotate-45 transition-transform duration-300">
              +
            </span>
          </summary>

          <div class="mt-6 border-t border-yellow-500/10 pt-6">
            <p class={ui.paragraph}>
              {item.resposta}
            </p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>