---
import { servicos } from "../../data/servicos";

const { atual } = Astro.props;

const listaServicos = Object.values(servicos).filter(
  (servico) => servico.slug !== atual
);
---

<section class="bg-black text-white py-24 px-6">
  <div class="max-w-7xl mx-auto">

    <div class="text-center mb-14">
      <span class="text-yellow-500 uppercase tracking-[0.35em] text-sm">
        Continue navegando
      </span>

      <h2 class="font-luxury text-4xl md:text-5xl font-semibold mt-4">
        Conheça também
      </h2>

      <p class="text-gray-300 mt-6 max-w-3xl mx-auto text-lg">
        Outros serviços do Ana's Beauty Shop para completar sua experiência de beleza.
      </p>
    </div>

    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {listaServicos.map((servico) => (
        <a
          href={`/servicos/${servico.slug}`}
          class="group block bg-[#111111] rounded-3xl overflow-hidden border border-yellow-500/20 hover:border-yellow-500 transition-all duration-500 hover:-translate-y-2"
        >
          <div class="overflow-hidden">
            <img
              src={servico.imagemDestaque}
              alt={servico.nome}
              class="w-full h-56 object-cover group-hover:scale-110 transition duration-700"
            />
          </div>

          <div class="p-7">
            <h3 class="font-luxury text-3xl text-yellow-400 mb-4">
              {servico.nome}
            </h3>

            <p class="text-gray-300 leading-relaxed mb-6">
              {servico.subtitulo}
            </p>

            <span class="text-yellow-400 font-semibold group-hover:text-yellow-300 transition">
              Saiba mais →
            </span>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>