---
type Etapa = {
  numero: string;
  titulo: string;
  texto: string;
};

const { servico } = Astro.props;
---

<section class="bg-black text-white py-24 px-6">
  <div class="max-w-7xl mx-auto">

    <div class="text-center mb-16">
      <span class="text-yellow-500 uppercase tracking-[0.35em] text-sm">
        Como funciona
      </span>

      <h2 class="font-luxury text-4xl md:text-5xl font-semibold mt-4">
        Uma experiência pensada em cada detalhe
      </h2>

      <p class="text-gray-300 max-w-3xl mx-auto mt-6 text-lg leading-relaxed">
        Do primeiro contato até a finalização, cada etapa é conduzida com cuidado,
        atenção e profissionalismo.
      </p>
    </div>

    <div class="grid gap-8 md:grid-cols-4">
      {servico.etapas.map((item: Etapa) => (
        <article class="relative bg-[#111111] border border-yellow-500/20 rounded-3xl p-8 hover:border-yellow-500 transition-all duration-500">
          <span class="block text-yellow-500 text-5xl font-bold mb-6">
            {item.numero}
          </span>

          <h3 class="font-luxury text-3xl text-yellow-400 mb-4">
            {item.titulo}
          </h3>

          <p class="text-gray-300 leading-relaxed">
            {item.texto}
          </p>
        </article>
      ))}
    </div>

  </div>
</section>