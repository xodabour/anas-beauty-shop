---
import type { IntroducaoServicoData } from "../../types/componentes";
import { ui } from "../../data/ui";

interface Props {
  servico: IntroducaoServicoData;
}

const { servico } = Astro.props as Props;
---

<section class={`bg-[#080808] ${ui.sectionAlt}`}>
  <div class={`${ui.containerMedium} grid lg:grid-cols-2 gap-12 items-center`}>
    <div>
      <span class={ui.eyebrowSmall}>
        Sobre o procedimento
      </span>

      <h2 class={`${ui.title} mt-4 mb-8`}>
        {servico.nome} no Ana's Beauty Shop
      </h2>

      <div class="space-y-6">
        {servico.introducao.map((paragrafo) => (
          <p class={ui.paragraph}>
            {paragrafo}
          </p>
        ))}
      </div>
    </div>

    <div class={ui.imageCard}>
      <img
        src={servico.imagemDestaque}
        alt={servico.nome}
        class="w-full h-[360px] md:h-[460px] object-cover"
      />
    </div>
  </div>
</section>