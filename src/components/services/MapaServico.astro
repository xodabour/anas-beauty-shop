---
import { config } from "../../data/config";
import { ui } from "../../data/ui";
---

<section class={`bg-black text-white ${ui.section}`}>
  <div class={ui.container}>
    <div class="text-center mb-14">
      <span class={ui.eyebrow}>
        Localização
      </span>

      <h2 class={`${ui.title} mt-4`}>
        Estamos em {config.cidade}
      </h2>

      <p class={`${ui.paragraph} mt-6 max-w-3xl mx-auto`}>
        Atendemos na {config.endereco}.
      </p>
    </div>

    <div class={ui.imageCard}>
      <iframe
        src={config.googleMapsEmbed}
        width="100%"
        height="450"
        style="border:0;"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
    </div>
  </div>
</section>