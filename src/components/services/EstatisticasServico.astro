---
const { servico } = Astro.props;
---

<section class="bg-[#080808] text-white py-10 px-5 md:py-12 md:px-6">
  <div class="max-w-7xl mx-auto">

    <div class="grid grid-cols-2 gap-4 md:grid-cols-4 md:gap-6">

      <div class="text-center bg-black rounded-2xl md:rounded-3xl border border-yellow-500/20 p-5 md:p-8">
        <div class="text-yellow-500 text-2xl md:text-4xl mb-3">
          ★★★★★
        </div>

        <div class="text-3xl md:text-4xl font-bold">
          4.9
        </div>

        <p class="text-gray-400 text-sm md:text-base mt-2">
          Avaliação no Google
        </p>
      </div>

      <div class="text-center bg-black rounded-2xl md:rounded-3xl border border-yellow-500/20 p-5 md:p-8">
        <div class="text-yellow-500 text-3xl md:text-5xl font-bold">
          300+
        </div>

        <p class="text-gray-400 text-sm md:text-base mt-2">
          Clientes atendidas
        </p>
      </div>

      <div class="text-center bg-black rounded-2xl md:rounded-3xl border border-yellow-500/20 p-5 md:p-8">
        <div class="text-yellow-500 text-3xl md:text-5xl font-bold">
          {servico.servicosOferecidos.length}
        </div>

        <p class="text-gray-400 text-sm md:text-base mt-2">
          Serviços capilares
        </p>
      </div>

      <div class="text-center bg-black rounded-2xl md:rounded-3xl border border-yellow-500/20 p-5 md:p-8">
        <div class="text-yellow-500 text-3xl md:text-5xl font-bold">
          BC
        </div>

        <p class="text-gray-400 text-sm md:text-base mt-2">
          Centro de Balneário Camboriú
        </p>
      </div>

    </div>

  </div>
</section>