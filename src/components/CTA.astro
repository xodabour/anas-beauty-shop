---
import { config } from "../data/config";
import { ui } from "../data/ui";
---

<section
  data-aos="zoom-in"
  class={`bg-black text-white ${ui.section}`}
>
  <div class={`${ui.containerSmall} text-center border border-yellow-500/30 rounded-[2rem] p-12 bg-[#111111]`}>
    <span class={ui.eyebrowSmall}>
      Agende seu horário
    </span>

    <h2 class={`${ui.title} mt-4 mb-6`}>
      Pronta para realçar sua beleza?
    </h2>

    <p class={`${ui.paragraph} mb-10`}>
      Fale conosco pelo WhatsApp e escolha o melhor horário para cuidar de você.
    </p>

    <a
      href={config.whatsapp(
        "Olá! Gostaria de agendar um horário."
      )}
      target="_blank"
      rel="noopener noreferrer"
      class={ui.buttonPrimary}
    >
      Agendar pelo WhatsApp
    </a>
  </div>
</section>