---
const photos = [
  { src: '/images/gallery/01.jpeg', type: 'unhas' },
  { src: '/images/gallery/02.jpeg', type: 'unhas' },
  { src: '/images/gallery/03.jpeg', type: 'unhas' },
  { src: '/images/gallery/04.jpeg', type: 'cabelo' },
  { src: '/images/gallery/05.jpeg', type: 'cabelo' },
  { src: '/images/gallery/06.jpeg', type: 'cabelo' },
];
---

<section
  data-aos="zoom-in"
  class="bg-black text-white py-24 px-6"
>
  <div class="max-w-7xl mx-auto">

    <div class="text-center mb-16">
      <span class="text-yellow-500 uppercase tracking-[0.3em] text-sm">
        Nossa Galeria
      </span>

      <h2 class="font-luxury text-5xl md:text-6xl font-semibold mt-4">
        Inspire-se com nossos trabalhos
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-6">

      {photos.map((photo) => (
        <div
          class={`relative rounded-3xl overflow-hidden group ${
            photo.type === 'cabelo'
              ? 'h-[500px]'
              : 'h-[260px]'
          }`}
        >
          <img
            src={photo.src}
            alt="Ana's Beauty Shop"
            class={`w-full h-full group-hover:scale-110 transition duration-700 ${
              photo.type === 'cabelo'
                ? 'object-cover object-top'
                : 'object-cover'
            }`}
          />

          <div
            class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition duration-500 flex items-end p-8"
          >
            <span
              class="bg-yellow-500 text-black px-6 py-3 rounded-full font-semibold"
            >
              Ver Mais
            </span>
          </div>
        </div>
      ))}

    </div>

  </div>
</section>