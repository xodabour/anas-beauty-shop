<header
  id="siteHeader"
  class="fixed top-0 left-0 w-full z-50 bg-black/30 backdrop-blur-md border-b border-yellow-500/10 transition-all duration-300"
>
  <div class="max-w-7xl mx-auto px-6 py-4">
    <div class="grid grid-cols-3 items-center">
      <nav class="hidden md:flex items-center gap-8 text-white font-medium">
        <a href="#inicio" class="hover:text-yellow-500 transition">Início</a>

        <div class="relative group">
          <button class="hover:text-yellow-500 transition flex items-center gap-1">
            Serviços <span>⌄</span>
          </button>

          <div class="fixed left-0 top-[80px] w-full opacity-0 invisible translate-y-4 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 hover:opacity-100 hover:visible hover:translate-y-0 transition-all duration-300 grid grid-cols-4 bg-black/95 border-t border-yellow-500/20">
            {[
              ['Bem-estar', 'Massagens, terapias e muito mais.'],
              ['Cabelos', 'Cortes, coloração e tratamentos.'],
              ['Cílios', 'Alongamentos e curvaturas.'],
              ['Lábios', 'Cor e volume para seus lábios.'],
              ['Pele', 'Cuidados personalizados.'],
              ['Saúde Capilar', 'Protocolos exclusivos.'],
              ['Sobrancelhas', 'Modelagem e design.'],
              ['Unhas', 'Acabamento elegante.'],
            ].map(([title, text]) => (
              <a href="#servicos" class="min-h-64 p-8 bg-[#111111] hover:bg-yellow-500/20 border border-yellow-500/10 transition">
                <h3 class="text-4xl font-bold text-white mb-4">{title}</h3>
                <p class="text-gray-300 text-lg">{text}</p>
                <span class="inline-block mt-8 bg-white text-black px-6 py-3 rounded font-semibold">Saiba mais</span>
              </a>
            ))}
          </div>
        </div>
      </nav>

      <div class="flex justify-center col-start-2">
        <a href="#inicio">
          <img src="/images/logo-dourada.png" alt="Ana's Beauty Shop" class="h-16 object-contain" />
        </a>
      </div>

      <nav class="hidden md:flex justify-end items-center gap-8 text-white font-medium">
        <a href="#contato" class="hover:text-yellow-500 transition">Contato</a>
        <a href="#sobre" class="hover:text-yellow-500 transition">Sobre Nós</a>
      </nav>

      <button
        id="menuButton"
        class="md:hidden col-start-3 justify-self-end text-yellow-500 text-3xl"
        aria-label="Abrir menu"
      >
        ☰
      </button>
    </div>
  </div>

  <div
    id="mobileMenu"
    class="md:hidden fixed top-[80px] right-0 w-full bg-black/95 border-t border-yellow-500/20 text-white opacity-0 invisible -translate-y-4 transition-all duration-300"
  >
    <nav class="flex flex-col p-6 gap-5 text-lg font-medium">
      <a href="#inicio" class="mobile-link hover:text-yellow-500 transition">Início</a>
      <a href="#servicos" class="mobile-link hover:text-yellow-500 transition">Serviços</a>
      <a href="#sobre" class="mobile-link hover:text-yellow-500 transition">Sobre Nós</a>
      <a href="#contato" class="mobile-link hover:text-yellow-500 transition">Contato</a>

      <a
        href="https://wa.me/554733663992"
        target="_blank"
        class="bg-yellow-500 text-black px-6 py-3 rounded-full text-center font-semibold mt-4"
      >
        Agendar pelo WhatsApp
      </a>
    </nav>
  </div>
</header>

<script>
  const menuButton = document.getElementById("menuButton");
  const mobileMenu = document.getElementById("mobileMenu");
  const links = document.querySelectorAll(".mobile-link");
  const siteHeader = document.getElementById("siteHeader");

  menuButton?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("opacity-0");
    mobileMenu?.classList.toggle("invisible");
    mobileMenu?.classList.toggle("-translate-y-4");
  });

  links.forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu?.classList.add("opacity-0", "invisible", "-translate-y-4");
    });
  });

  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      siteHeader?.classList.remove("bg-black/30", "border-yellow-500/10");
      siteHeader?.classList.add("bg-black/90", "shadow-2xl", "border-yellow-500/30");
    } else {
      siteHeader?.classList.remove("bg-black/90", "shadow-2xl", "border-yellow-500/30");
      siteHeader?.classList.add("bg-black/30", "border-yellow-500/10");
    }
  });
</script>