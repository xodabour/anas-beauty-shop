---
import { config } from "../data/config";
import { ui } from "../data/ui";
---

<section
  id="inicio"
  class="relative min-h-screen overflow-hidden bg-black md:flex md:items-center"
>
  <!-- Desktop -->
  <div
    class="hidden md:block absolute inset-0 bg-cover bg-center scale-105"
    style="background-image: url('/images/hero-salao.png');"
  ></div>

  <div class="hidden md:block absolute inset-0 bg-black/65"></div>
  <div class="hidden md:block absolute inset-0 bg-gradient-to-r from-black/80 via-black/50 to-transparent"></div>

  <!-- Mobile -->
  <div class="md:hidden pt-24 bg-black">
    <div class="relative bg-black flex justify-center items-center px-4 overflow-hidden">
      <img
        src="/images/hero-salao.png"
        alt={`Equipe ${config.nome}`}
        class="w-full max-h-[520px] object-contain"
      />

      <div
        class="absolute inset-x-0 bottom-0 h-72 bg-gradient-to-t from-black via-black/80 to-transparent"
      ></div>
    </div>

    <div class="bg-black text-center px-7 pb-16 -mt-16 relative z-10">
      <span class="text-yellow-400 uppercase tracking-[0.35em] text-xs font-medium">
        {config.nome}
      </span>

      <h1 class="font-luxury text-white text-4xl font-semibold leading-tight mt-5 mb-6">
        Sua beleza merece a melhor das experiências
      </h1>

      <p class={`${ui.paragraph} mb-8`}>
        Cada detalhe é pensado para realçar sua essência com sofisticação,
        cuidado e elegância.
      </p>

      <a
        href={config.whatsapp("Olá! Gostaria de agendar um horário.")}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block w-full bg-yellow-500 text-black px-8 py-4 rounded-full font-bold uppercase shadow-xl shadow-yellow-500/25"
      >
        Agende sua experiência
      </a>
    </div>
  </div>

  <!-- Desktop -->
  <div class={`hidden md:block relative z-10 ${ui.container} px-8 w-full`}>
    <div class="max-w-4xl">
      <span class="text-yellow-400 uppercase tracking-[0.45em] text-sm font-medium">
        {config.nome}
      </span>

      <h1 class="font-luxury text-white text-5xl md:text-6xl lg:text-7xl font-semibold leading-[1.1] mt-6 max-w-4xl">
        Sua beleza merece uma experiência inesquecível.
      </h1>

      <p class={`${ui.paragraph} md:text-xl mt-8 mb-12 max-w-2xl`}>
        Sofisticação, elegância e bem-estar em um ambiente pensado para você em
        {config.cidade}.
      </p>

      <div class="flex flex-col sm:flex-row gap-5">
        <a
          href={config.whatsapp("Olá! Gostaria de agendar um horário.")}
          target="_blank"
          rel="noopener noreferrer"
          class={ui.buttonPrimary}
        >
          Agendar pelo WhatsApp
        </a>

        <a
          href="#servicos"
          class="border border-yellow-500 text-yellow-400 px-10 py-4 rounded-full font-semibold text-center hover:bg-yellow-500 hover:text-black hover:scale-105 transition-all duration-300"
        >
          Conheça nossos serviços
        </a>
      </div>
    </div>
  </div>
</section>